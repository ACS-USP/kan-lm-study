# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
build/
dist/

# Checkpoints (large binaries — track only best.pt via git-lfs or exclude entirely)
checkpoints/

# Tokenizer is small enough to track
!tokenizer.json

# Logs and local state
*.log
.DS_Store
.env

# uv
uv.lock

# Paper generated figures (regenerated by make_figures.py)
paper/figures/*.pdf
paper/figures/*.png

# Review materials (not part of the paper codebase)
review_results/

# LaTeX build artifacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.out
paper/*.log
paper/*.fls
paper/*.fdb_latexmk
